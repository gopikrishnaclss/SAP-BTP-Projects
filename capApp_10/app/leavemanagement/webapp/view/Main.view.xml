<mvc:View controllerName="leavemanagement.controller.Main"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:tnt="sap.tnt"
  xmlns:core="sap.ui.core"
  xmlns:t="sap.ui.table"
  xmlns:m="sap.m">
  <tnt:ToolPage id="toolPage">
    <tnt:header>
      <tnt:ToolHeader id="shellLikeToolHeader" class="sapUiTinyMargin">
        <Button icon="sap-icon://menu2" type="Transparent" tooltip="Menu"
          press="onCollapseExpandPress">
          <layoutData>
            <OverflowToolbarLayoutData priority="NeverOverflow" />
          </layoutData>
        </Button>
        <Title
            id="idTitle"
            text="Leave Management"
            level="H3"
            class="clickableTitle sapUiTinyMarginBegin">
          <layoutData>
            <OverflowToolbarLayoutData priority="Disappear" />
          </layoutData>
        </Title>
        <ToolbarSpacer />
        <Button text="Holiday List"
            type="Emphasized"
            icon="sap-icon://time-off"
            class="sapUiTinyMarginEnd"
            press="onHolidayListButtonPress"/>
        <Button icon="sap-icon://person-placeholder" type="Transparent" press="pressUserIcon" >
          <layoutData>
            <OverflowToolbarLayoutData priority="NeverOverflow" />
          </layoutData>
        </Button>
      </tnt:ToolHeader>
    </tnt:header>
    <tnt:sideContent>
      <tnt:SideNavigation
        expanded="true"
        itemPress=".onItemPress"
        selectedKey="{sideNav>/selectedKey}"
        itemSelect=".onnavigation"
        class="customSideitemNav"
        id="sideNavigation">
        <tnt:NavigationList items="{path: 'sideNav>/navigation'}">
          <tnt:NavigationListItem
            text="{sideNav>title}"
            icon="{sideNav>icon}"
            enabled="{sideNav>enabled}"
            expanded="{sideNav>expanded}"
            items="{sideNav>items}"
            selectable="{= ${sideNav>items}.length > 3}"
            key="{key}">
            <tnt:NavigationListItem
              text="{sideNav>title}"
              key="{sideNav>key}"
              icon="{sideNav>icon}"
              enabled="{sideNav>enabled}" />
          </tnt:NavigationListItem>
        </tnt:NavigationList>
      </tnt:SideNavigation>
    </tnt:sideContent>
    <tnt:mainContents>
      <NavContainer initialPage="Home" id="pageContainer" class="mainPage">
        <pages>
          <!-- Home Page -->
          <ScrollContainer id="Home" height="100%" vertical="true" >
            <VBox class="sapUiSmallMargin">
              <!-- Dashboard -->
              <Panel
                headerText="Dashboard"
                class="sapUiMediumMarginTop homePanel">
                <content>
                  <!-- Welcome Section -->
                  <VBox class="sapUiSmallMarginBottom">
                    <Title text="Welcome Back, Gopi" level="H6"/>
                    <Text text="Manage your leaves efficiently"/>
                  </VBox>
                  <!-- Summary Cards -->
                  <HBox wrap="Wrap">
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedCasual"
                      header="Casual Leave"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="{leavebalance>/Casual}" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedSick"
                      header="Sick Leave"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="{leavebalance>/Sick}" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedPaid"
                      header="Paid Leave"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="{leavebalance>/Paid}" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedPending"
                      header="Pending Requests"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="1" />
                      </TileContent>
                    </GenericTile>
                  </HBox>
                </content>
              </Panel>
              <!-- Recent Requests -->
              <Panel
                  headerText="Recent Leave Requests"
                  class="sapUiMediumMarginTop">
                <Table items="{/LeaveRequests}">
                  <columns>
                    <Column>
                      <Text text="Leave Type"/>
                    </Column>
                    <Column>
                      <Text text="From"/>
                    </Column>
                    <Column>
                      <Text text="To"/>
                    </Column>
                    <Column>
                      <Text text="Status"/>
                    </Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <cells>
                        <Text text="{leaveType}"/>
                        <Text text="{fromDate}"/>
                        <Text text="{toDate}"/>
                        <ObjectStatus text="Approved" state="Success"/>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </Panel>
            </VBox>
          </ScrollContainer>
          <!-- Apply Leave Page -->
          <ScrollContainer id="page1">
            <VBox id="applyLeaveSection" class="sapUiSmallMargin">
              <Panel headerText="Apply Leave" class="sapUiSmallMargin">
                <content>
                  <HBox class="sapUiSmallMargin">
                    <VBox width="33.3%">
                      <Label text="From Date: " labelFor="DP1" />
                      <DatePicker
                        id="DP1"
                        placeholder="Enter Date"
                        change=".handleChange"
                        class="sapUiSmallMarginBottom" />
                    </VBox>
                    <VBox class="sapUiSmallMarginBegin" width="33.3%">
                      <Label text="To Date: " labelFor="DP2" />
                      <DatePicker
                        id="DP2"
                        placeholder="Enter Date"
                        change=".handleChange"
                        class="sapUiSmallMarginBottom" />
                    </VBox>
                    <VBox class="sapUiSmallMarginBegin" width="33.3%">
                      <Label text="Leave" labelFor="Leave" />
                      <HBox>
                        <ComboBox
                          id="Leave"
                          items="{
                          path: '/LeaveTypes',
                          sorter: { path: 'leaveType' }
                        }">
                          <core:Item key="{leaveTypeId}" text="{leaveType}" />
                        </ComboBox>
                        <Button class="sapUiSmallMarginBegin" type="Emphasized" text="Apply"
                          press="onApplyLeave" />
                      </HBox>
                    </VBox>
                  </HBox>
                  <VBox class="sapUiSmallMarginBegin">
                    <Label text="Reason" />
                    <TextArea id="reason" />
                  </VBox>
                </content>
              </Panel>
              <Panel headerText="Available Leave" class="sapUiSmallMargin">
                <content>
                  <HBox>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedCasual"
                      header="Casual"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="{leavebalance>/Casual}" withMargin="false" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedSick"
                      header="Sick"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="{leavebalance>/Sick}" withMargin="false" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedPaid"
                      header="Paid"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="{leavebalance>/Paid}" withMargin="false" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedPending"
                      header="Pending Requests"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="1" />
                      </TileContent>
                    </GenericTile>
                  </HBox>
                </content>
              </Panel>
            </VBox>
          </ScrollContainer>
          <!-- My Leaves Page -->
          <!-- <ScrollContainer id="page2">
          </ScrollContainer> -->
        </pages>
      </NavContainer>
    </tnt:mainContents>
  </tnt:ToolPage>
</mvc:View>