<mvc:View controllerName="leavemanagement.controller.Main"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:tnt="sap.tnt"
  xmlns:core="sap.ui.core"
  xmlns:t="sap.ui.table"
  xmlns:m="sap.m">
  <tnt:ToolPage id="toolPage">
    <tnt:header>
      <tnt:ToolHeader id="shellLikeToolHeader" class="sapUiTinyMargin">
        <Button icon="sap-icon://menu2" type="Transparent" tooltip="Menu"
          press="onCollapseExpandPress">
          <layoutData>
            <OverflowToolbarLayoutData priority="NeverOverflow" />
          </layoutData>
        </Button>
        <Title text="Leave Management" wrapping="false" id="productName">
          <layoutData>
            <OverflowToolbarLayoutData priority="Disappear" />
          </layoutData>
        </Title>
        <ToolbarSpacer />
        <SearchField width="25rem" id="searchField">
          <layoutData>
            <OverflowToolbarLayoutData priority="Low" group="1" />
          </layoutData>
        </SearchField>
        <Button visible="false" icon="sap-icon://search" type="Transparent" id="searchButton"
          tooltip="Search" />
        <Button text="Logout" type="Transparent" press="onLogout" icon="sap-icon://log">
          <layoutData>
            <OverflowToolbarLayoutData priority="NeverOverflow" />
          </layoutData>
        </Button>
      </tnt:ToolHeader>
    </tnt:header>
    <tnt:sideContent>
      <tnt:SideNavigation
        expanded="true"
        itemPress=".onItemPress"
        selectedKey="{sideNav>/selectedKey}"
        itemSelect=".onnavigation"
        class="customSideitemNav"
        id="sideNavigation">
        <tnt:NavigationList items="{path: 'sideNav>/navigation'}">
          <tnt:NavigationListItem
            text="{sideNav>title}"
            icon="{sideNav>icon}"
            enabled="{sideNav>enabled}"
            expanded="{sideNav>expanded}"
            items="{sideNav>items}"
            selectable="{= ${sideNav>items}.length > 3}"
            key="{key}">
            <tnt:NavigationListItem
              text="{sideNav>title}"
              key="{sideNav>key}"
              icon="{sideNav>icon}"
              enabled="{sideNav>enabled}" />
          </tnt:NavigationListItem>
        </tnt:NavigationList>
      </tnt:SideNavigation>
    </tnt:sideContent>
    <tnt:mainContents>
      <NavContainer initialPage="Home" id="pageContainer">
        <pages>
          <!-- Home Page -->
          <ScrollContainer id="Home">
            <VBox class="sapUiMediumMargin">
              <Table id="employeesTable" items="{/Employees}">
                <headerToolbar>
                  <Toolbar>
                    <Title text="Employees" />
                  </Toolbar>
                </headerToolbar>
                <columns>
                  <Column width="11rem">
                    <Text text="Name" />
                  </Column>
                  <Column width="11rem">
                    <Text text="Email" />
                  </Column>
                  <Column width="6rem">
                    <Text text="Team" />
                  </Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{firstName}" />
                      <Text text="{email}" />
                      <Text text="{Team}" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </VBox>
          </ScrollContainer>
          <!-- Apply Leave Page -->
          <ScrollContainer id="page1">
            <VBox id="applyLeaveSection" class="sapUiSmallMargin">
              <Panel headerText="Apply Leave" class="sapUiSmallMargin">
                <content>
                  <HBox class="sapUiSmallMargin">

                    <VBox width="33.3%">
                      <Label text="From Date: " labelFor="DP1" />
                      <DatePicker
                        id="DP1"
                        placeholder="Enter Date"
                        change=".handleChange"
                        class="sapUiSmallMarginBottom" />

                    </VBox>

                    <VBox class="sapUiSmallMarginBegin" width="33.3%">
                      <Label text="To Date: " labelFor="DP2" />
                      <DatePicker
                        id="DP2"
                        placeholder="Enter Date"
                        change=".handleChange"
                        class="sapUiSmallMarginBottom" />

                    </VBox>

                    <VBox class="sapUiSmallMarginBegin" width="33.3%">
                      <Label text="Leave" labelFor="Leave" />
                      <HBox>
                        <ComboBox
                          id="Leave"
                          items="{
                          path: '/LeaveTypes',
                          sorter: { path: 'leaveType' }
                        }">
                          <core:Item key="{leaveTypeId}" text="{leaveType}" />
                        </ComboBox>
                        <Button class="sapUiSmallMarginBegin" type="Emphasized" text="Apply"
                          press="onApplyLeave" />
                      </HBox>

                    </VBox>
                  </HBox>
                  <VBox class="sapUiSmallMarginBegin">
                    <Label text="Reason" />
                    <TextArea id="reason" />

                  </VBox>
                  <!-- <t:Table
                    id="leaveBalancesTable"
                    rows="{/LeaveBalances}"
                    selectionMode="None"
                    width="auto">
                    <t:columns>
                      <t:Column width="11rem">
                        <m:Label text="Leave Type"/>
                        <t:template>
                          <m:Text text="{leaveType_ID}" wrapping="false"/>
                        </t:template>
                      </t:Column>
                      <t:Column width="6rem">
                        <m:Label text="Year"/>
                        <t:template>
                          <m:Text text="{year}"/>
                        </t:template>
                      </t:Column>
                      <t:Column width="9rem">
                        <m:Label text="Total Allowed"/>
                        <t:template>
                          <m:Text text="{totalAllowed}"/>
                        </t:template>
                      </t:Column>
                      <t:Column width="9rem">
                        <m:Label text="Leave Used"/>
                        <t:template>
                          <m:Text text="{used}"/>
                        </t:template>
                      </t:Column>
                      <t:Column width="12rem">
                        <m:Label text="Remaining"/>
                        <t:template>
                          <m:Text text="{remaining}"/>
                        </t:template>
                      </t:Column>
                      <t:Column width="12rem">
                        <m:Label text="Apply"/>
                        <t:template>
                           <Button text="Apply"/>
                        </t:template>
                      </t:Column>
                    </t:columns>
                  </t:Table> -->
                </content>
              </Panel>
              <Panel headerText="Available Leave" class="sapUiSmallMargin">
                <content>
                  <HBox>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedCasual"
                      header="Casual"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="{leavebalance>/Casual}" withMargin="false" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedSick"
                      header="Sick"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="{leavebalance>/Sick}" withMargin="false" />
                      </TileContent>
                    </GenericTile>

                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedPaid"
                      header="Paid"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="{leavebalance>/Paid}" withMargin="false" />
                      </TileContent>
                    </GenericTile>
                  </HBox>
                </content>
              </Panel>
            </VBox>
          </ScrollContainer>
          <!-- My Leaves Page -->
          <ScrollContainer id="page2">
            <VBox id="myLeaves" class="sapUiMediumMargin">
              <Panel headerText="My Leaves">
                <content>
                  <t:Table
                    rows="{/LeaveRequests}"
                    selectionMode="MultiToggle"
                     
                     >
                    <t:columns>
                      <t:Column width="11rem">
                        <m:Label text="Leave Type" />
                        <t:template>
                          <m:Text text="{leaveType}"  />
                        </t:template>
                      </t:Column>

                    </t:columns>
                  </t:Table>
                </content>
              </Panel>
            </VBox>
          </ScrollContainer>
        </pages>
      </NavContainer>
    </tnt:mainContents>
  </tnt:ToolPage>
</mvc:View>