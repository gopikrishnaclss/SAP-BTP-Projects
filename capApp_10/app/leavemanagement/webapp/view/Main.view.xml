<mvc:View controllerName="leavemanagement.controller.Main"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:tnt="sap.tnt"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.ui.layout.form"
  xmlns:t="sap.ui.table"
  xmlns:m="sap.m">
  <tnt:ToolPage id="toolPage">
    <tnt:header>
      <tnt:ToolHeader id="shellLikeToolHeader" class="sapUiTinyMargin">
        <Button icon="sap-icon://menu2" type="Transparent" tooltip="Menu"
          press="onCollapseExpandPress">
          <layoutData>
            <OverflowToolbarLayoutData priority="NeverOverflow" />
          </layoutData>
        </Button>
        <Title
          id="idTitle"
          text="Leave Management"
          level="H3"
          class="clickableTitle sapUiTinyMarginBegin">
          <layoutData>
            <OverflowToolbarLayoutData priority="Disappear" />
          </layoutData>
        </Title>
        <ToolbarSpacer />
        <Button text="Holiday List"
          type="Emphasized"
          icon="sap-icon://time-off"
          class="sapUiTinyMarginEnd"
          press="onHolidayListButtonPress" />
        <Button icon="sap-icon://person-placeholder" type="Transparent" press="pressUserIcon">
          <layoutData>
            <OverflowToolbarLayoutData priority="NeverOverflow" />
          </layoutData>
        </Button>
      </tnt:ToolHeader>
    </tnt:header>
    <tnt:sideContent>
      <tnt:SideNavigation
        expanded="true"
        itemPress=".onItemPress"
        selectedKey="{sideNav>/selectedKey}"
        itemSelect=".onnavigation"
        class="customSideitemNav"
        id="sideNavigation">
        <tnt:NavigationList items="{path: 'sideNav>/navigation'}">
          <tnt:NavigationListItem
            text="{sideNav>title}"
            icon="{sideNav>icon}"
            enabled="{sideNav>enabled}"
            expanded="{sideNav>expanded}"
            items="{sideNav>items}"
            selectable="{= ${sideNav>items}.length > 0}"
            key="{sideNav>key}">
            <tnt:NavigationListItem
              text="{sideNav>title}"
              key="{sideNav>key}"
              icon="{sideNav>icon}"
              enabled="{sideNav>enabled}" />
          </tnt:NavigationListItem>
        </tnt:NavigationList>
      </tnt:SideNavigation>
    </tnt:sideContent>
    <tnt:mainContents>
      <NavContainer initialPage="Home" id="pageContainer" class="mainPage">
        <pages>
          <!-- Home Page -->
          <ScrollContainer id="Home" height="100%" vertical="true">
            <VBox class="sapUiSmallMargin">
              <!-- Dashboard -->
              <Panel
                headerText="Dashboard"
                class="sapUiMediumMarginTop homePanel">
                <content>
                  <!-- Welcome Section -->
                  <VBox class="sapUiSmallMarginBottom">
                    <Title text="Welcome Back, {currentUser>/firstName}" level="H6" />
                    <Text text="Manage your leaves efficiently" />
                  </VBox>
                  <!-- Summary Cards -->
                  <HBox wrap="Wrap">
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedCasual"
                      header="Casual Leave"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent
                          value="{leavebalance>/Casual/remaningLeaves}" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedSick"
                      header="Sick Leave"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent
                          value="{leavebalance>/Sick/remaningLeaves}" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedPaid"
                      header="Paid Leave"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent
                          value="{leavebalance>/Paid/remaningLeaves}" />
                      </TileContent>
                    </GenericTile>
                    <GenericTile
                      class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout reportPublishedPending"
                      header="Pending Requests"
                      frameType="OneByHalf">
                      <TileContent>
                        <NumericContent value="1" />
                      </TileContent>
                    </GenericTile>
                  </HBox>
                </content>
              </Panel>
              <!-- Recent Requests -->
              <Panel
                headerText="Recent Leave Requests"
                class="sapUiMediumMarginTop">
                <Table items="{leaveRequest>/}">
                  <columns>
                    <Column>
                      <Text text="Leave Type" />
                    </Column>
                    <Column>
                      <Text text="From" />
                    </Column>
                    <Column>
                      <Text text="To" />
                    </Column>
                    <Column>
                      <Text text="Status" />
                    </Column>
                  </columns>

                  <items>
                    <ColumnListItem>
                      <cells>
                        <Text text="{leaveRequest>leaveType/leaveType}" />
                        <Text text="{leaveRequest>fromDate}" />
                        <Text text="{leaveRequest>toDate}" />
                        <Text text="{leaveRequest>status}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </Panel>
            </VBox>
          </ScrollContainer>
          <!-- Apply Leave Page -->
          <ScrollContainer id="page1" height="100%" vertical="true">
    <VBox id="applyLeaveSection" class="sapUiSmallMargin">

        <!-- Main Layout: Sidebar + Form using HBox -->
        <Panel headerText="Apply Leave">
            <content>
                <HBox>

                    <!-- LEFT SIDEBAR: Leave Balance -->
                    <VBox
                        width="20%"
                        class="sapUiSmallMargin">

                        <Title text="Leave Balance" level="H6" class="sapUiTinyMarginBottom" />

                        <!-- Casual -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom balanceSidebarItem balanceSidebarActive">
                            <HBox alignItems="Center">
                                <core:Icon src="sap-icon://sun" class="sapUiTinyMarginEnd casualIcon" />
                                <VBox>
                                    <Text text="Casual" class="balanceSidebarLabel" />
                                    <Text text="Selected" class="balanceSidebarSub" />
                                </VBox>
                            </HBox>
                            <ObjectNumber
                                number="{leavebalance>/Casual/remaningLeaves}"
                                state="Success" />
                        </HBox>

                        <!-- Sick -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom balanceSidebarItem">
                            <HBox alignItems="Center">
                                <core:Icon src="sap-icon://stethoscope" class="sapUiTinyMarginEnd sickIcon" />
                                <Text text="Sick" class="balanceSidebarLabel" />
                            </HBox>
                            <ObjectNumber
                                number="{leavebalance>/Sick/remaningLeaves}"
                                state="Error" />
                        </HBox>

                        <!-- Paid -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom balanceSidebarItem">
                            <HBox alignItems="Center">
                                <core:Icon src="sap-icon://time-off" class="sapUiTinyMarginEnd paidIcon" />
                                <Text text="Paid" class="balanceSidebarLabel" />
                            </HBox>
                            <ObjectNumber
                                number="{leavebalance>/Paid/remaningLeaves}"
                                state="Warning" />
                        </HBox>

                        <!-- Divider -->
                        <HBox class="sapUiTinyMarginTop sapUiTinyMarginBottom">
                            <core:HTML content="&lt;hr style='width:100%;border:none;border-top:1px solid #e5e5e5;'/&gt;" />
                        </HBox>

                        <!-- Pending -->
                        <HBox
                            justifyContent="SpaceBetween"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom">
                            <HBox alignItems="Center">
                                <core:Icon src="sap-icon://pending" class="sapUiTinyMarginEnd pendingIcon" />
                                <Text text="Pending" class="balanceSidebarLabel" />
                            </HBox>
                            <ObjectStatus
                                text="1"
                                state="Warning" />
                        </HBox>

                    </VBox>

                    <!-- VERTICAL DIVIDER -->
                    <core:HTML content="&lt;div style='width:1px;background:#e5e5e5;margin:8px 12px;'&gt;&lt;/div&gt;" />

                    <!-- RIGHT SIDE: Apply Leave Form -->
                    <VBox width="78%" class="sapUiSmallMargin">

                        <!-- Row 1: From Date | To Date | No. of Days | Leave Type -->
                        <HBox>
                            <VBox width="25%">
                                <Label text="From Date:" labelFor="DP1" design="Bold" />
                                <DatePicker
                                    id="DP1"
                                    placeholder="DD-MM-YYYY"
                                    change="handleChange"
                                    width="95%"
                                    class="sapUiSmallMarginBottom" />
                            </VBox>
                            <VBox class="sapUiSmallMarginBegin" width="25%">
                                <Label text="To Date:" labelFor="DP2" design="Bold" />
                                <DatePicker
                                    id="DP2"
                                    placeholder="DD-MM-YYYY"
                                    change="handleChange"
                                    width="95%"
                                    valueState="{/toDateState}"
                                    valueStateText="End date must be after start date"
                                    class="sapUiSmallMarginBottom" />
                            </VBox>
                            <VBox class="sapUiSmallMarginBegin" width="25%">
                                <Label text="No. of Days:" labelFor="noOfDays" design="Bold" />
                                <Input
                                    id="noOfDays"
                                    value="{/noOfDays}"
                                    editable="false"
                                    width="95%"
                                    class="sapUiSmallMarginBottom" />
                            </VBox>
                            <VBox class="sapUiSmallMarginBegin" width="25%">
                                <Label text="Leave Type:" labelFor="Leave" design="Bold" />
                                <ComboBox
                                    id="Leave"
                                    width="95%"
                                    class="sapUiSmallMarginBottom"
                                    items="{
                                        path: '/LeaveTypes',
                                        sorter: { path: 'leaveType' }
                                    }">
                                    <core:Item key="{leaveTypeId}" text="{leaveType}" />
                                </ComboBox>
                            </VBox>
                        </HBox>

                        <!-- Row 2: Reason -->
                        <VBox class="sapUiSmallMarginTop">
                            <Label text="Reason:" labelFor="reason" design="Bold" />
                            <TextArea
                                id="reason"
                                rows="3"
                                placeholder="Briefly describe the reason for your leave..."
                                width="100%" />
                        </VBox>

                        <!-- Row 3: Buttons -->
                        <HBox justifyContent="End" class="sapUiSmallMarginTop">
                            <Button
                                text="Cancel"
                                type="Default"
                                press="onCancelLeave"
                                class="sapUiSmallMarginEnd" />
                            <Button
                                text="Submit Request"
                                type="Emphasized"
                                icon="sap-icon://send"
                                press="onApplyLeave" />
                        </HBox>

                    </VBox>
                </HBox>
            </content>
        </Panel>

    </VBox>
</ScrollContainer>
          <!-- Employee Profile Page -->
          <ScrollContainer id="page2" height="100%" vertical="true">
              <VBox class="sapUiMediumMargin">
                  <!-- Profile Header -->
                  <Panel headerText="Employee Profile">
                      <content>
                          <HBox alignItems="Center" class="sapUiMediumMarginBottom">
                              <!-- Profile Avatar -->
                              <Avatar
                                  displaySize="XL"
                                  initials="{= ${currentUser>/firstName}.substring(0,1) }"
                                  class="sapUiMediumMarginEnd" />
                              <!-- Basic Details -->
                              <VBox>
                                  <Title
                                      text="{currentUser>/firstName}"
                                      level="H3" />
                                  <Text
                                      text="{currentUser>/email}" />
                                  <ObjectStatus
                                      text="Active Employee"
                                      state="Success"
                                      class="sapUiTinyMarginTop" />
                              </VBox>
                          </HBox>
                          <!-- Employee Information -->
                          <f:SimpleForm
                              editable="false"
                              layout="ResponsiveGridLayout"
                              columnsXL="2"
                              columnsL="2"
                              columnsM="1">
                              <Label text="Employee ID" />
                              <Text text="{currentUser>/employeeId}" />
                              <Label text="Team" />
                              <Text text="{currentUser>/Team}" />
                              <Label text="Email" />
                              <Text text="{currentUser>/email}" />
                              <Label text="Designation" />
                              <Text text="SAP Fiori Developer" />
                              <Label text="Location" />
                              <Text text="Chennai" />
                              <Label text="Joining Date" />
                              <Text text="10-Jan-2025" />
                          </f:SimpleForm>
                      </content>
                  </Panel>
                  <!-- Contact Information -->
                  <Panel
                      headerText="Contact Information"
                      class="sapUiMediumMarginTop">
                      <content>
                          <List>
                              <StandardListItem
                                  title="Phone"
                                  description="+91 9876543210"
                                  icon="sap-icon://phone" />
                              <StandardListItem
                                  title="Email"
                                  description="{currentUser>/email}"
                                  icon="sap-icon://email" />
                              <StandardListItem
                                  title="Location"
                                  description="Chennai"
                                  icon="sap-icon://map" />
                          </List>
                      </content>
                  </Panel>
              </VBox>
                    </ScrollContainer>
        </pages>
      </NavContainer>
    </tnt:mainContents>
  </tnt:ToolPage>
</mvc:View>