<core:FragmentDefinition 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core" 
    xmlns:l="sap.ui.layout"	
    xmlns:f="sap.ui.layout.form">
    <Dialog id="createPasswordDialog" showHeader="false">
        <content>
            <VBox>
                <f:SimpleForm id="SimpleFormChange354"
                    editable="true"
                    layout="ResponsiveGridLayout"
                    title="Change Password"
                    labelSpanXL="5"
                    labelSpanL="5"
                    labelSpanM="5"
                    labelSpanS="12"
                    adjustLabelSpan="false"
                    emptySpanXL="2"
                    emptySpanL="2"
                    emptySpanM="2"
                    emptySpanS="0"
                    columnsXL="5"
                    columnsL="5"
                    columnsM="5"
                    singleContainerFullSize="false" >
                    <f:content>
                         <HBox width="350px" justifyContent="Center" alignItems="Center">
                            <MessageStrip id="successMessageStrip" type="Success" visible="false"
                                showIcon="true" class="sapUiSmallMarginBottom" />
                            <MessageStrip id="errorMessageStrip" type="Error" visible="false"
                                showIcon="true" class="sapUiSmallMarginBottom"/>
                         </HBox>
                        <Label text="User ID" />
                        <Input id="userId" value="{currentUser>/employeeId}" editable="false"/>
                        <Label text="Enter Existing Password" />
                        <Input id="idOldPassword" type="Password"/>
                        <Label text="Create New Password" />
                        <Input id="idNewPassword" type="Password"/>
                        <Label text="Confirm New Password" />
                        <Input id="idConformPassword" type="Password"/>
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </content>
        <buttons>
            <Button text="Submit" type="Emphasized" press="onUpdatePassword"/>
            <Button text="Cancel" type="Transparent" press="onChangePasswordFragmentClose"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>